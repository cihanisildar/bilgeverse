  description  String?
  date         DateTime
  startTime    String?
  endTime      String?
  location     String?              @default("Spor Salonu")
  type         AthleteTrainingType  @default(TRAINING)
  coachId      String?
  coach        User?                @relation("CoachTrainings", fields: [coachId], references: [id])
