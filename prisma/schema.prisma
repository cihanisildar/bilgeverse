  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  branches           SportBranch[]         @relation("BranchAthletes")
  attendances        AthleteAttendance[]   @relation("AthleteAttendances")
  performances       AthletePerformance[]  @relation("AthletePerformances")
  evaluations        AthleteEvaluation[]   @relation("AthleteEvaluations")
  disciplineRecords  DisciplineRecord[]    @relation("AthleteDisciplineRecords")
  matchParticipations MatchParticipation[] @relation("AthleteMatchParticipations")
