model SportBranch {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  athletes      AthleteProfile[]    @relation("BranchAthletes")
  trainings     AthleteTraining[]   @relation("BranchTrainings")
  tournaments   Tournament[]        @relation("BranchTournaments")
  matches       SportMatch[]        @relation("BranchMatches")
  equipment     Equipment[]         @relation("BranchEquipment")
  announcements SportAnnouncement[] @relation("BranchAnnouncements")
}

model AthleteProfile {
  id                 String                @id @default(uuid())
  userId             String                @unique
  user               User                  @relation("UserAthleteProfile", fields: [userId], references: [id], onDelete: Cascade)
  healthReportExpiry DateTime?
  birthDate          DateTime?
  phone              String?
  parentName         String?
  parentPhone        String?
  membershipStatus   MembershipStatus      @default(ACTIVE)
  licenseNumber      String?
  licenseExpiry      DateTime?
