  value      String // "10", "45.5s", "5km"
  notes      String?
  training   AthleteTraining   @relation("TrainingPerformances", fields: [trainingId], references: [id], onDelete: Cascade)
  athlete    AthleteProfile    @relation("AthletePerformances", fields: [athleteId], references: [id], onDelete: Cascade)

  @@index([trainingId])
  @@index([athleteId])
}

enum AthleteTrainingType {
  TRAINING
  MATCH
}

enum AthleteMetricType {
  SCORE
  TIME
  DISTANCE
  OTHER
}

enum MembershipStatus {
  ACTIVE
  PASSIVE
  SUSPENDED
}

enum EquipmentStatus {
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
}

enum MatchResult {
  WIN
  LOSS
  DRAW
  PENDING
}

enum TournamentStatus {
  UPCOMING
  ONGOING
  COMPLETED
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
}

enum FeedbackStatus {
  NEW
  IN_REVIEW
  RESOLVED
}

model OrientationProcess {
  id            String               @id @default(cuid())
  studentId     String               @unique
  student       User                 @relation("StudentOrientation", fields: [studentId], references: [id], onDelete: Cascade)
  startDate     DateTime             @default(now())
  week1Notes    String?
  week2Notes    String?
  week3Notes    String?
  status        OrientationStatus    @default(ONGOING)
  decision      OrientationDecision?
  decisionNotes String?
  decisionDate  DateTime?
  decidedById   String?
  decidedBy     User?                @relation("DecidedOrientation", fields: [decidedById], references: [id])

  @@index([studentId])
  @@index([decidedById])
}

model ExpulsionRecord {
  id             String   @id @default(cuid())
  studentName    String
  studentSurname String
  username       String?
  email          String?
  phone          String?
  expulsionDate  DateTime @default(now())
  responsibleId  String
  responsible    User     @relation("ExpulsionResponsible", fields: [responsibleId], references: [id])
  reason         String
  notes          String?

  @@index([responsibleId])
  @@index([expulsionDate])
}

model AcademyLesson {
  id          String              @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  startDate   DateTime?
  capacity    Int?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  assignments AcademyAssignment[]
  sessions    AcademySession[]
  students    AcademyStudent[]
  syllabus    AcademySyllabus?
  materials   AcademyMaterial[]
  tasks       AcademyTask[]
  notes       AcademyStudentNote[]
}

enum AcademyMaterialType {
  PDF
  VIDEO
  DOCUMENT
  LINK
}

enum AcademyNoteType {
  NOTE
  EVALUATION
  OBSERVATION
}

model AcademyMaterial {
  id           String              @id @default(uuid())
  lessonId     String
  title        String
  description  String?
  type         AcademyMaterialType @default(LINK)
  url          String
  fileKey      String?
  uploadedById String
  createdAt    DateTime            @default(now())
  lesson       AcademyLesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  uploadedBy   User                @relation("AcademyMaterials", fields: [uploadedById], references: [id])

  @@index([lessonId])
}

model AcademyStudentNote {
  id        String          @id @default(uuid())
  lessonId  String
  studentId String
  authorId  String
  type      AcademyNoteType @default(NOTE)
  content   String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  lesson    AcademyLesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student   User            @relation("AcademyStudentNotesReceived", fields: [studentId], references: [id], onDelete: Cascade)
  author    User            @relation("AcademyStudentNotesAuthored", fields: [authorId], references: [id])

  @@index([lessonId, studentId])
}

model AcademyTask {
  id          String                  @id @default(uuid())
  lessonId    String
  title       String
  description String?
  points      Int                     @default(0)
  dueDate     DateTime?
  createdById String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  lesson      AcademyLesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdBy   User                    @relation("AcademyTasksCreated", fields: [createdById], references: [id])
  completions AcademyTaskCompletion[]

  @@index([lessonId])
}

model AcademyTaskCompletion {
  id                  String      @id @default(uuid())
  taskId              String
  studentId           String
  completedAt         DateTime    @default(now())
  awardedById         String
  pointsTransactionId String?
  task                AcademyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  student             User        @relation("AcademyTaskCompletions", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([taskId, studentId])
  @@index([studentId])
}

model AcademyAssignment {
  id       String        @id @default(uuid())
  lessonId String
  userId   String
  role     UserRole
  lesson   AcademyLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user     User          @relation("AcademyAssignments", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lessonId, userId])
}

model AcademyStudent {
  id        String        @id @default(uuid())
  lessonId  String
  studentId String
  joinedAt  DateTime      @default(now())
  lesson    AcademyLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student   User          @relation("AcademyStudents", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([lessonId, studentId])
}

model AcademySyllabus {
  id        String                @id @default(uuid())
  lessonId  String                @unique
  lesson    AcademyLesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  items     AcademySyllabusItem[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

model AcademySyllabusItem {
  id          String          @id @default(uuid())
  syllabusId  String
  orderIndex  Int
  title       String
  description String?
  syllabus    AcademySyllabus @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model AcademySession {
  id          String              @id @default(uuid())
  lessonId    String
  tutorId     String
  title       String
  description String?
  date        DateTime
  startTime   String?
  endTime     String?
  lesson      AcademyLesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tutor       User                @relation("AcademySessions", fields: [tutorId], references: [id], onDelete: Cascade)
  attendances AcademyAttendance[]
}

model AcademyAttendance {
  id            String         @id @default(uuid())
  sessionId     String
  studentId     String
  status        Boolean        @default(false)
  checkInMethod CheckInMethod  @default(MANUAL)
  checkInTime   DateTime?
  session       AcademySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student       User           @relation("AcademyAttendances", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
}
